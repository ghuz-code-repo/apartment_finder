FLASK_ENV=production
SECRET_KEY=change-me-to-random-secret
MAIN_DATABASE_URL=sqlite:///main_app.db
PLANNING_DATABASE_URL=sqlite:///planning.db
MAIL_SERVER=mail.example.com
MAIL_SERVER_PORT=587
SEND_FROM_EMAIL=robot@example.com
SEND_FROM_EMAIL_PASSWORD=change-me

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=-123456789

# MySQL source database
SOURCE_MYSQL_URI=mysql+pymysql://user:password@host:port/database

# Auth service configuration (Gateway integration)
AUTH_SERVICE_URL=http://auth-service:80
JWT_SECRET=change-me
INTERNAL_API_KEY=change-me
BEHIND_PROXY=true
CONTAINER_NAME=apartment-finder-app
